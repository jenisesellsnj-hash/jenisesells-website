{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://real-estate-star.com/agent-content.schema.json",
  "title": "Agent Content",
  "description": "Content configuration for a Real Estate Star agent website",
  "type": "object",
  "required": ["template", "sections"],
  "properties": {
    "template": {
      "type": "string",
      "enum": ["emerald-classic"],
      "description": "Template name to render"
    },
    "sections": {
      "type": "object",
      "required": ["hero", "stats", "services", "how_it_works", "sold_homes", "testimonials", "cma_form", "about", "city_pages"],
      "properties": {
        "hero": {
          "$ref": "#/$defs/section",
          "properties": {
            "data": {
              "type": "object",
              "required": ["headline", "tagline", "cta_text", "cta_link"],
              "properties": {
                "headline": { "type": "string" },
                "tagline": { "type": "string" },
                "cta_text": { "type": "string" },
                "cta_link": { "type": "string" }
              }
            }
          }
        },
        "stats": {
          "$ref": "#/$defs/section",
          "properties": {
            "data": {
              "type": "object",
              "required": ["items"],
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["value", "label"],
                    "properties": {
                      "value": { "type": "string" },
                      "label": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "services": {
          "$ref": "#/$defs/section",
          "properties": {
            "data": {
              "type": "object",
              "required": ["items"],
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["title", "description"],
                    "properties": {
                      "title": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "how_it_works": {
          "$ref": "#/$defs/section",
          "properties": {
            "data": {
              "type": "object",
              "required": ["steps"],
              "properties": {
                "steps": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["number", "title", "description"],
                    "properties": {
                      "number": { "type": "integer" },
                      "title": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "sold_homes": {
          "$ref": "#/$defs/section",
          "properties": {
            "data": {
              "type": "object",
              "required": ["items"],
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["address", "city", "state", "price"],
                    "properties": {
                      "address": { "type": "string" },
                      "city": { "type": "string" },
                      "state": { "type": "string" },
                      "price": { "type": "string" },
                      "sold_date": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "testimonials": {
          "$ref": "#/$defs/section",
          "properties": {
            "data": {
              "type": "object",
              "required": ["items"],
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["text", "reviewer", "rating"],
                    "properties": {
                      "text": { "type": "string" },
                      "reviewer": { "type": "string" },
                      "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                      "source": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "cma_form": {
          "$ref": "#/$defs/section",
          "properties": {
            "data": {
              "type": "object",
              "required": ["title", "subtitle"],
              "properties": {
                "title": { "type": "string" },
                "subtitle": { "type": "string" }
              }
            }
          }
        },
        "about": {
          "$ref": "#/$defs/section",
          "properties": {
            "data": {
              "type": "object",
              "required": ["bio"],
              "properties": {
                "bio": { "type": "string" },
                "credentials": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        },
        "city_pages": {
          "$ref": "#/$defs/section",
          "properties": {
            "data": {
              "type": "object",
              "required": ["cities"],
              "properties": {
                "cities": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["slug", "city", "state", "county", "highlights", "market_snapshot"],
                    "properties": {
                      "slug": { "type": "string" },
                      "city": { "type": "string" },
                      "state": { "type": "string" },
                      "county": { "type": "string" },
                      "highlights": { "type": "array", "items": { "type": "string" } },
                      "market_snapshot": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["enabled", "data"],
      "properties": {
        "enabled": { "type": "boolean" },
        "data": { "type": "object" }
      }
    }
  }
}
